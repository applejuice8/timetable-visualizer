{
  "manifest_version": 3,
  "name": "Timetable Visualizer",
  "version": "1.0",

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/scrape.js", "content-scripts/select.js"]
    }
  ],

  "action": {
    "default_popup": "popup/timetable.html"
  },

  "background": {
    "service_worker": "background/background.js"
  }
}
