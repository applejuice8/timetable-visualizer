{
  "manifest_version": 3,
  "name": "Timetable Helper",
  "version": "1.0",

  "permissions": ["activeTab", "scripting"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scrape.js", "select.js"]
    }
  ],

  "action": {
    "default_popup": "timetable.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}
